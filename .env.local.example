APP_ENV=local

# MySQL（Dockerコンテナ名で接続）
DB_HOST=localhost
DB_PORT=43306
DB_SCHEMA=sandbox
DB_USER=dbuser
DB_PASSWORD=dbpassword

# Redis（Dockerコンテナ名で接続）
REDIS_HOST=localhost
REDIS_PORT=46379

# AWS Cognito JWT
JWT_ISSUER=https://cognito-idp.ap-northeast-1.amazonaws.com/YOUR_USER_POOL_ID
JWT_AUDIENCE1=YOUR_APP_CLIENT_ID
# JWT_AUDIENCE2=YOUR_APP_CLIENT_ID_2
# JWT_AUDIENCE3=YOUR_APP_CLIENT_ID_3

# CORS許可オリジン
JWT_ORIGIN1=http://localhost:3000
# JWT_ORIGIN2=http://localhost:4000

# 為替レートAPI
FX_RATE_URL=https://navi.gaitame.com/v3/info/prices/rate

# ファイルストレージ
STORAGE_BUCKET=./local/storage
STORAGE_FX=fx

# 経済指標除外リスト（カンマ区切り）
INDICATOR_EXCLUDE_LIST="本日掲載の指標はありません","休場","韓国","ポーランド","日銀・金融政策決定会合（"

# 経済指標CSVの削除リスト（カンマ区切り、該当文字列を空文字に置換）
INDICATOR_STRIP_LIST="植田和男","黒田東彦"

# CSVインポート設定
CSV_BULK_LOAD_SIZE=500
IMPORT_CHECK_SKIP=false

# セッション
SESSION_TTL=3600

# サーバー
SERVER_PORT=8080
GIN_MODE=debug
