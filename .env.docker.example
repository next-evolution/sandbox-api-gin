APP_ENV=docker

# MySQL（Dockerコンテナ名で接続）
DB_HOST=sandbox-db
DB_PORT=3306
DB_SCHEMA=sandbox_local
DB_USER=dbuser
DB_PASSWORD=dbpassword

# Redis（Dockerコンテナ名で接続）
REDIS_HOST=sandbox-redis
REDIS_PORT=6379

# AWS Cognito JWT
JWT_ISSUER1=https://cognito-idp.ap-northeast-1.amazonaws.com/YOUR_USER_POOL_ID
JWT_AUDIENCE1=YOUR_APP_CLIENT_ID
# JWT_AUDIENCE2=YOUR_APP_CLIENT_ID_2
# JWT_AUDIENCE3=YOUR_APP_CLIENT_ID_3

# CORS許可オリジン
JWT_ORIGIN1=http://localhost:3000
# JWT_ORIGIN2=http://localhost:4000

# セッション
SESSION_TTL=3600

# サーバー
SERVER_PORT=8080
GIN_MODE=debug
